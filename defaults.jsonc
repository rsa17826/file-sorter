{
  "paths to watch": [
    {
      "path": "C:/Users/user/default path to sort", // path to sort files in
      "settings": {
        // settings for sorting the path
        "#include": ["default settings"], // (none|list[str]): list of things to include EX: ["testing", "test2"] will include $root/testing and $root/test2 - includes have priority baised on order so last in list have highest priority, things not included have highest priority
        "move folders with extensions as files": true,
        "move folders if all same inside": true,
        "ignores": [
          { "#include": ["default settings/ignores"] }, // if dict in arr and dict only has key "#include" will act as an include statement and include from the included paths merging with the array - same priority as the other #include statement
        ],
        "sort folders": {
          // (dict): dict containing the extensions and the place to move them
          "png": "testmain",
        },
        "min time": 30, // the min time in seconds that the file has to be old before it can be moved - this is date modified not date created - if there is an unmoveable file from this setting it will resort after the file moveable again - only will resort after the max wait time has past EX: if file has 1 sec left and another has 10 secs left will resort after 10 secs
        "max time": 60, // this is the max time in seconds that the file can be and still be moved
      },
    },
  ],
  "default settings": {
