      "media/images/lospec pixel editor": "lospec pixel editor", // (str): set the folder icon at {key} to the icon at {value} {value} can be abs or relative to the folder that is being sorted, if no icon is found will also check the ./icons folder relative to the running script for the file, if it doesnt end with .ico .ico will be added to the end - only accepts icons that end with .ico
    },
    "move folders if all same inside": true, // (bool): if all items inside the folder would go to the same folder will move the folder to the folder that the items inside would = false
    "clear empty on run": true, // (bool): if true when starting will remove all empty folders - a folder is also empty if all folders inside are also empty - a folder is empty ignoring "desktop.ini" and "foldericon.ico" = false
    "move folders with extensions as files": false, // (bool): if true will move folders as if they were filee EX: folder "test.txt" will be moved same as if it was a file if false ignore folders when moving = false
    "delete file if same at dest": true, // (bool): if true will delete file instead of moving if a file with same name and content exists at the destination = false
    "ignorefolders": [".stfolder", ".stversions"], // (list[str]): list of strings of foldernames to ignore - NOT USEFUL NOW can just use ignores instead
    "ignores": [
      {
        "type": "regex",
        "in": "filename",
        "value": "^\\.",
      },
      {
        "type": "plain",
        "in": "filename",
        "value": ".stfolder",
      },
      {
        "type": "plain", // ("regex"|"plain"): the type of matching to do
        "in": "filename", // ("filename"|"filepath"): the data to compare against
        "value": ".stversions", // (string): the value to compare against
        "ignorecase": true, // (boolean): = false
      },
      {
        "type": "regex",
        "in": "filename",
        "value": "\\.TMP",
        "ignorecase": true,
      },
    ],
  },
