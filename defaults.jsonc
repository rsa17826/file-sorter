      "rpmsg": "messages", // (str): {key} file extension to move {value} the folder absolute or relative to the sorted folder
      "t": "TRASH", // ("TRASH"): moves the file to the recycle bin
      "FOLDER": "folders go here", // ("FOLDER"): if there is a folder that hasn't been moved by "move folders if all same inside" or "move folders with extensions as files" and is not one of the folders that other things are being moved to, then it will be moved to {value}
      "": "files with no extension", // (""): if there is a file that has no extension, not just an unmatched extension, then it will be moved to {value}
      "UNMOVED": "all unmoved things go here", // ("UNMOVED"): if there is a file or folder that hasn't been moved, then it will be moved to {value} - "FOLDER" has priority over "UNMOVED"
